{
  "name": "second-brain-ai-electron",
  "version": "1.0.0",
  "description": "Second Brain AI Electron Desktop",
  "main": "./out/main/index.js",
  "author": "codeagent",
  "scripts": {
    "start": "electron-vite preview",
    "dev": "electron-vite dev",
    "build": "npm run build:frontend && electron-vite build && node scripts/copy_frontend.js && electron-builder",
    "build:win": "npm run build:electron && npm run copy:frontend && npm run build:builder",
    "build:mac": "electron-vite build && electron-builder --mac",
    "build:linux": "electron-vite build && electron-builder --linux",
    "build:frontend": "cd frontend && npm install && npm run build",
    "build:electron": "electron-vite build",
    "copy:frontend": "node scripts/copy_frontend.js",
    "build:builder": "electron-builder --win"
  },
  "dependencies": {
    "axios": "^1.6.7",
    "electron-log": "^5.0.0",
    "electron-updater": "^6.1.8",
    "tree-kill": "^1.2.2"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^6.0.1",
    "electron": "^28.2.0",
    "electron-builder": "^24.9.1",
    "electron-vite": "^2.0.0",
    "typescript": "^5.3.0",
    "vite": "^5.0.0"
  },
  "build": {
    "appId": "com.secondbrain.ai",
    "productName": "Second Brain AI",
    "publish": null,
    "directories": {
      "output": "dist"
    },
    "win": {
      "target": [
        "nsis",
        "zip"
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "runAfterFinish": false
    },
    "extraResources": [
      {
        "from": "backend/dist/backend",
        "to": "backend",
        "filter": [
          "**/*"
        ]
      }
    ]
  }
}